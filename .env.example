# Allowed Origins: Comma-separated list of fully-qualified URLs (e.g. https://example.com)
# Set to * to allow all origins.
ALLOWED_ORIGINS=*

# Proxy API Key: Optional secure token to authenticate incoming requests.
# If configured, client must send the X-Proxy-API-Key or Bearer token header.
PROXY_API_KEY=your-secure-internal-proxy-key-here