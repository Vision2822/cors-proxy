{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": null,
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 60,
      "supportsCancellation": true
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}